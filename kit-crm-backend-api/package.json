{
  "name": "kit-crm-backend-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prod": "cross-env NODE_ENV=production tsx ./bin/www.ts",
    "staging": "cross-env NODE_ENV=staging tsx ./bin/www.ts",
    "dev": "cross-env NODE_ENV=development tsx watch ./bin/www.ts",
    "start": "cross-env NODE_ENV=development tsx watch ./bin/www.ts",
    "db:generate": "cross-env NODE_ENV=development npx drizzle-kit generate --config=./db/drizzle/drizzle.config.ts",
    "db:migrate": "cross-env NODE_ENV=development npx drizzle-kit migrate --config=./db/drizzle/drizzle.config.ts",
    "prod:db:generate": "cross-env NODE_ENV=production npx drizzle-kit generate --config=./db/drizzle/drizzle.config.ts",
    "prod:db:migrate": "cross-env NODE_ENV=production npx drizzle-kit migrate --config=./db/drizzle/drizzle.config.ts",
    "staging:db:generate": "cross-env NODE_ENV=staging npx drizzle-kit generate --config=./db/drizzle/drizzle.config.ts",
    "staging:db:migrate": "cross-env NODE_ENV=staging npx drizzle-kit migrate --config=./db/drizzle/drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=development node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "cross-env NODE_ENV=development node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "cross-env NODE_ENV=development node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:create-user": "cross-env NODE_ENV=development tsx __tests__/create-test-user.ts"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "express": "~4.16.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "~1.9.1",
    "pg": "^8.18.0",
    "postgres": "^3.4.5",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.4.0",
    "@jest/globals": "^29.7.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.6",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
